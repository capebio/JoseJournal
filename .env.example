# JOSE v1 — environment. Copy to .env. Defaults match docker-compose.yml.

# Persistence mode: 'memory' (deterministic, no services) or 'live' (real stack)
PERSISTENCE=memory

NODE_ENV=development
PORT=3000

# CouchDB (content versions, drafts, public projections)
COUCH_URL=http://admin:josepw@localhost:5984
COUCH_DB_CONTENT=jose_content
COUCH_DB_PUBLIC=jose_public

# PostgreSQL (control plane: releases, DOIs, consent, grants, audit, TDWG, identity/trust)
PG_HOST=localhost
PG_PORT=5432
PG_USER=jose
PG_PASSWORD=josepw
PG_DATABASE=jose

# Elastic (index only)
ELASTIC_NODE=http://localhost:9200

# Redis (queues, caches, leaderboards-sorted-sets)
REDIS_HOST=localhost
REDIS_PORT=6379

# Swift / S3-compatible (MinIO) content-addressed media masters
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=joseminio
S3_SECRET_KEY=joseminiopw
S3_BUCKET=jose-media

# Keycloak (SSO; ORCID federated as OIDC provider)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=jose
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/jose/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://localhost:8080/realms/jose
# When 'true', the Keycloak guard accepts a signed dev token (HS256) for local/e2e without Keycloak running.
AUTH_DEV_MODE=true
AUTH_DEV_SECRET=jose-dev-secret

# DOI agency (§12.5 OPEN — DataCite default for data-rich objects)
DOI_AGENCY=datacite
DOI_PREFIX=10.80000

# Media: verification resolution is always free (§9.9). Max free zoom edge (px).
MEDIA_FREE_VERIFICATION_MAX_EDGE=8192
