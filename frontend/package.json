    "gen:api": "openapi-typescript http://localhost:3000/api-json -o src/core/api/openapi.d.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.16",
    "pouchdb-browser": "^9.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/pouchdb-browser": "^6.1.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "openapi-typescript": "^7.4.2",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
